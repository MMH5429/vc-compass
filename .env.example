# ──────────────────────────────────────────────────────────────
#  Vektor — VC Intelligence Dashboard
#  Environment Variables
#
#  Copy this file to .env.local and fill in your API keys.
#  Never commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# Clearbit Company Enrichment API (primary enrichment source)
# Docs:    https://dashboard.clearbit.com/docs#enrichment-api-company-api
# Get key: https://dashboard.clearbit.com/keys
# Note:    Free tier supports ~50 enrichments/month
VITE_CLEARBIT_API_KEY=

# Hunter.io Domain Search API (optional — adds email signal data)
# Docs:    https://hunter.io/api-documentation/v2#domain-search
# Get key: https://hunter.io/api-keys
# Note:    Free tier supports 25 searches/month
VITE_HUNTER_API_KEY=
